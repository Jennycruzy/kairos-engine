# Bitquery — Mode B live bonding curve subscriptions
BITQUERY_API_KEY=
BITQUERY_WS_ENDPOINT=wss://streaming.bitquery.io/eap

# Neynar — Mode B Farcaster broadcast
NEYNAR_API_KEY=
NEYNAR_SIGNER_UUID=

# Membase / Unibase MCP — shared by both modes
# Sign up at hub.membase.unibase.com to get these three values
MEMBASE_ACCOUNT=
MEMBASE_CONVERSATION_ID=
MEMBASE_ID=

# BNB Greenfield — shared archive
GREENFIELD_PRIVATE_KEY=
GREENFIELD_ACCOUNT_ADDRESS=

# ERC-8004 Agent Identity
AGENT_OWNER_PRIVATE_KEY=          # Signs ERC-8004 registration tx on BNB Chain
BNB_RPC_URL=https://bsc-dataseed.binance.org/
KAIROS_AGENT_ID=                  # Auto-populated after first registration; leave blank on first run

# LLM — Mnemon + Launch Advisor
ANTHROPIC_API_KEY=

# Embeddings — Themis vector similarity
OPENAI_API_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
